    "preact": "^10.29.6"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.10.5",
    "nodemon": "^3.1.14",
    "playwright": "^1.59.1",
    "typescript": "^6.0.3",
    "vite": "^8.1.3"
  }
