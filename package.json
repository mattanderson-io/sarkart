  "description": "SARkart Plotly - experimental Plotly.js-based charts fork of SARkart",
  "main": "index.js",
  "scripts": {
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0",
    "start": "node src/ensure-build.js && node src/index.js",
