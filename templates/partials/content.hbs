<div id="content" class="scrolling">

  <section class="container-fluid">
    <!-- Top bar -->
    <div class="top-bar" id="topBar">
      <div class="top-bar-info" id="fileInfoBar">
        <div class="file-info-group">
          <span class="file-info-label">Host</span>
          <span class="file-info-value num" id="fileInfoHost">&mdash;</span>
        </div>
        <div class="file-info-group">
          <span class="file-info-label">OS</span>
          <span class="file-info-value num" id="fileInfoOS">&mdash;</span>
        </div>
        <div class="file-info-group">
          <span class="file-info-label">Dates</span>
          <span class="file-info-value num" id="fileInfoDates">&mdash;</span>
        </div>
        <div class="file-info-group">
          <span class="file-info-label">File</span>
          <span class="file-info-value num" id="fileInfoName" title="">&mdash;</span>
        </div>
      </div>

      <div class="top-bar-actions">
        <button type="button" class="top-bar-btn" id="btnThemeToggle" title="Toggle theme" aria-label="Toggle theme">
          <svg class="icon icon-moon" viewBox="0 0 24 24" aria-hidden="true"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
          <svg class="icon icon-sun" viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
        </button>
        <a href="#" class="top-bar-btn toolbar-post-upload" id="btnCmdk" title="Command palette (⌘K)">
          <svg class="icon" viewBox="0 0 24 24" aria-hidden="true"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4.3-4.3"/></svg>
          <kbd>⌘K</kbd>
        </a>
        <div class="top-bar-menu toolbar-post-upload">
          <button type="button" class="top-bar-btn top-bar-menu-btn" id="btnTopMenu" aria-haspopup="menu" aria-expanded="false" aria-controls="topBarMenuPanel" title="Menu">
            <svg class="icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M4 6h16M4 12h16M4 18h16"/></svg>
          </button>
          <div class="top-bar-menu-panel" id="topBarMenuPanel" role="menu" hidden>
            <a href="#" class="top-bar-menu-item" id="btnOpenAnother" role="menuitem" title="Open another SAR file">
              <svg class="icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
              Open file
            </a>
            <a href="" class="top-bar-menu-item" id="btnReset" role="menuitem" title="Reload and clear all data">
              <svg class="icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M3 12a9 9 0 1 0 3-6.7"/><path d="M3 3v6h6"/></svg>
              Reset
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- Landing hero -->
    <div class="landing-hero-row">
      <h1 id="logo-header" class="landing-brand">
        <span class="landing-brand-lockup">
          <img class="landing-brand-logo" src="/images/racing-penguin.webp" alt="SARkart logo">
          <span class="landing-brand-text"><b>SAR</b><span>kart</span></span>
        </span>
        <span class="landing-brand-tagline">Unix SAR data, as charts</span>
      </h1>
    </div>

    <!-- Date range filter -->
    <div class="hide" id="dateFilterBlock">
      <div class="date-filter-card">
        <span class="date-filter-label">
          <svg class="icon" viewBox="0 0 24 24" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
          Date range
        </span>
        <select id="dateFilterMode" class="select-control">
          <option value="all">All days</option>
          <option value="single">Single day</option>
          <option value="range">Date range</option>
        </select>
        <select id="dateFilterStart" class="select-control" hidden></select>
        <span id="dateFilterRangeSep" hidden>to</span>
        <select id="dateFilterEnd" class="select-control" hidden></select>
        <button id="dateFilterApply" type="button" hidden>Apply</button>
        <span id="dateFilterInfo" class="num"></span>
      </div>
    </div>

    <!-- KPI cards -->
    <div class="remove" id="peakBlock">
      <div class="kpi-card contDash" data-kpi="cpu">
        <div class="kpi-top">
          <div>
            <div class="kpi-label">
              <svg class="icon" aria-hidden="true"><use href="#i-cpu"/></svg>
              Peak CPU
            </div>
            <div class="kpi-value"><span id="peakCPU">&nbsp;</span><sup>%</sup></div>
          </div>
          <div id="peakCPUChart"></div>
        </div>
        <div class="kpi-meta">
          <a href="#" class="small-box-footer" id="btnCPUArrow" title="View CPU chart">
            <span>at</span> <span id="peakCPUTime">&nbsp;</span>
            <svg class="icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </a>
        </div>
      </div>

      <div class="kpi-card contDash" data-kpi="load">
        <div class="kpi-top">
          <div>
            <div class="kpi-label">
              <svg class="icon" aria-hidden="true"><use href="#i-gauge"/></svg>
              Peak Load
            </div>
            <div class="kpi-value"><span id="peakLoad">&nbsp;</span></div>
          </div>
          <div id="peakLoadChart"></div>
        </div>
        <div class="kpi-meta">
          <a href="#" class="small-box-footer" id="btnLoadArrow" title="View Load chart">
            <span>at</span> <span id="peakLoadTime">&nbsp;</span>
            <svg class="icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </a>
        </div>
      </div>

      <div class="kpi-card contDash" data-kpi="memory">
        <div class="kpi-top">
          <div>
            <div class="kpi-label">
              <svg class="icon" aria-hidden="true"><use href="#i-memory"/></svg>
              Peak Memory
            </div>
            <div class="kpi-value"><span id="peakMemory"></span><sup>%</sup></div>
          </div>
          <div id="peakMemoryChart"></div>
        </div>
        <div class="kpi-meta">
          <a href="#" class="small-box-footer" id="btnMemoryArrow" title="View Memory chart">
            <span>at</span> <span id="peakMemoryTime">&nbsp;</span>
            <svg class="icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </a>
        </div>
      </div>
    </div>

    <!-- Landing upload -->
    <div class="landing-grid landing-hero">
      <div class="homeContBlock">
        <div class="upload-card">
          <div id="start" class="form-container uploader sar-file-uploader">
            <div class="upload-idle">
              <div class="upload-icon">
                <svg class="icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
              </div>
              <h3 class="upload-headline">Drop a SAR file to begin</h3>
              <p class="upload-sub">or use the button below. Plain-text SAR output from <code>sar -A</code>.</p>
              <span class="button-wrapper">
                <span id="file-upload-btn" class="btn uploadBtn">
                  <svg class="icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>
                  Browse and upload
                </span>
              </span>
              <p class="upload-privacy">
                <svg class="icon" viewBox="0 0 24 24" aria-hidden="true"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                Your file never leaves this machine
              </p>
              <div class="upload-filename-wrap">
                <span class="fileinput-filename"></span>
              </div>
            </div>

            <div class="d-none hide" id="spinner">
              <div id="progressContainer">
                <div class="progress-stages" aria-hidden="true">
                  <span class="progress-stage is-active" data-stage="reading">Reading</span>
                  <span class="progress-stage-sep"></span>
                  <span class="progress-stage" data-stage="parsing">Parsing</span>
                  <span class="progress-stage-sep"></span>
                  <span class="progress-stage" data-stage="rendering">Rendering</span>
                </div>
                <div id="progressStep">Preparing…</div>
                <div class="upload-progress-track">
                  <div id="progressBar"></div>
                </div>
                <div id="spinnerVal" class="num">0%</div>
                <div id="progressRate" class="progress-rate num"></div>
                <button id="btnProcessData" type="button" hidden>Process data</button>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="homeContBlock">
        <div class="landing-side">
          <div class="landing-side-header">
            <h2 class="landing-side-title">View Unix SAR data as interactive charts</h2>
            <p class="landing-side-lead">A local-only dashboard for peak CPU, memory, and load, with drill-downs per device and interface. Supports Linux, AIX, and Solaris.</p>
          </div>

          <ul class="landing-highlights">
            <li>
              <span class="hl-icon">
                <svg class="icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
              </span>
              <div>
                <strong>Up to 20&times; faster than sarchart</strong>
                <span>A 313&nbsp;MB RHEL&nbsp;9 SAR file loads in ~2 seconds.</span>
              </div>
            </li>
            <li>
              <span class="hl-icon">
                <svg class="icon" viewBox="0 0 24 24" aria-hidden="true"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
              </span>
              <div>
                <strong>Client-side only</strong>
                <span>Your file never leaves the browser. PDF export also runs locally.</span>
              </div>
            </li>
          </ul>

          <div class="landing-side-footer">
            <a href="#" id="btnTrySample" class="landing-side-link">Try with sample data &rarr;</a>
          </div>
        </div>
      </div>
    </div>

    <!-- Page title -->
    <div class="page-title-row contABlock section-header homeContBlock title-empty">
      <h2 class="boxed" id="pageTitle"></h2>
    </div>

    <!-- Chart containers -->
    <div class="chart-block contABlock homeContBlock">
      <div class="chart-card">
        <div class="chart-head is-empty">
          <h3 class="chart-heading"></h3>
          <p class="chart-subtitle"></p>
        </div>
        <div class="chart-body"><div id="containerA"></div></div>
        <p id="containerANotes" class="container-notes"></p>
      </div>
    </div>

    <div class="chart-block contBBlock homeContBlock">
      <div class="chart-card">
        <div class="chart-head is-empty">
          <h3 class="chart-heading"></h3>
          <p class="chart-subtitle"></p>
        </div>
        <div class="chart-body"><div id="containerB"></div></div>
        <p id="containerBNotes" class="container-notes"></p>
      </div>
    </div>

    <div class="chart-block contCBlock homeContBlock">
      <div class="chart-card">
        <div class="chart-head is-empty">
          <h3 class="chart-heading"></h3>
          <p class="chart-subtitle"></p>
        </div>
        <div class="chart-body"><div id="containerC"></div></div>
        <p id="containerCNotes" class="container-notes"></p>
      </div>
    </div>

    <div class="chart-block contDBlock homeContBlock">
      <div class="chart-card">
        <div class="chart-head is-empty">
          <h3 class="chart-heading"></h3>
          <p class="chart-subtitle"></p>
        </div>
        <div class="chart-body"><div id="containerD"></div></div>
        <p id="containerDNotes" class="container-notes"></p>
      </div>
    </div>

    <div class="chart-block contMBlock homeContBlock">
      <div class="chart-card">
        <h5 class="container-title" id="containerMTitle">&nbsp;</h5>
        <div class="chart-body"><div id="containerM"></div></div>
        <p id="containerMNotes" class="container-notes"></p>
      </div>
    </div>

  </section>

  {{>footer}}
</div>

<!-- Hidden file input anchor for export-pdf.js -->
<div class="container1" hidden aria-hidden="true"></div>
