        <div class="row mt-3 py-3 mx-0 landing-extra">
          <div class="col-lg-6 col-md-12 col-sm-12 col-xs-12 homeContBlock">
            <div class="card card-blur card-block contDash1 roundborder">
              <div class="card-header with-border">
                <i class="fa fa-download"></i>
                <h3 class="card-title" id="_howto">HOW TO GENERATE SAR FROM SERVER</h3>
              </div>
              <div class="card-body">
                <div class="paragraph text-left" style="text-align:left;">
                  <span>Login as root (or with sudo) access run the following commands to fetch the sar output for a
                    specific date or multiple dates.</span><br><br>
                  <font color="#ccc" size="3">Example:</font><span>
                  </span><br>

                  <!-- Nav tabs -->
                <ul class="nav nav-tabs" role="tablist">
                  <li class="nav-item">
                    <a class="nav-link active" data-bs-toggle="tab" href="#_linux">LINUX</a>
                  </li>
                  <li class="nav-item">
                    <a class="nav-link" data-bs-toggle="tab" href="#_aix">AIX</a>
                  </li>
                  <li class="nav-item">
                    <a class="nav-link" data-bs-toggle="tab" href="#_solaris">SOLARIS</a>
                  </li>
                </ul>

                <!-- Tab panes -->
                <div class="tab-content"><br>
                  <div id="_linux" class="container1 tab-pane active">
                    <font size="3">For single day file:</font>
                    <div class="code-block">                      
                      <span>sar -A -f /var/log/sa/sa<span class="tdate"></span> &gt; /tmp/sa<span
                          class="tdate"></span>_$(uname -n).txt</span>
                    </div>
                    <font size="3">For multiple days files:</font><br>
                    <div class="code-block">
                        ls /var/log/sa/sa?? | xargs -i sar -A -f {} &nbsp;&gt;&nbsp; /tmp/sar_$(uname -n).txt</font> <br>
                    </div>

                  </div>
                  <div id="_aix" class="container1 tab-pane fade">
                    <font size="3">For single day file:</font>
                    <div class="code-block">
                      <span>sar -A -f /var/adm/sa/sa<span class="tdate"></span> &gt; /tmp/sa<span
                          class="tdate"></span>_$(uname -n).txt</span></div>
                    <font size="3">For multiple days files:</font><br>
                    <div class="code-block">
                        ls /var/adm/sa/sa?? | xargs -i sar -A -f {} &nbsp;&gt;&nbsp; /tmp/sar_$(uname -n).txt</font> <br>
                    </div>
                  </div>
                  <div id="_solaris" class="container1 tab-pane fade">
                    <font size="3">For single day file:</font>
                    <div class="code-block">
                      <span>sar -A -f /var/log/sysstat/sa<span class="tdate"></span> &gt; /tmp/sa<span
                          class="tdate"></span>_$(uname -n).txt</span></div>
                    <font size="3">For multiple days files:</font><br>
                    <div class="code-block">
                        ls /var/log/sysstat/sa/sa?? | xargs -i sar -A -f {} &nbsp;&gt;&nbsp; /tmp/sar_$(uname -n).txt</font> <br>
                    </div>
                  </div>
                </div>

                </div>     

              </div>
            </div>
          </div>
          
          <!-- Begin Server Info box -->
          <div class="col-fluid col-lg-6 col-md-12 col-sm-12 col-xs-12 homeContBlock">
            <div class="card card-blur card-block contDash1 roundborder-inv">
