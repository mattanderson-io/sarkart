<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="utf-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <meta http-equiv="X-UA-Compatible" content="IE=edge">
        <meta property="og:url" content="https://github.com/mattanderson-io/sarkart" />
        <meta property="og:type" content="website" />
        <meta property="og:title" content="SARkart" />
        <meta property="og:description" content="Fast, local tool for viewing Unix SAR data as interactive charts" />
        <meta property="og:image" content="/images/racing-penguin-favicon.webp" />
        <title>SARkart</title>
        <link rel="icon" href="/images/racing-penguin-favicon.webp" sizes="any" type="image/webp">

        <script>
          (function () {
            var m = document.cookie.match(/(?:^|;\s*)sarkart-theme=(light|dark)(?:;|$)/);
            var theme = m ? m[1] : 'dark';
            document.documentElement.setAttribute('data-theme', theme);
          })();
        </script>

        <link rel="stylesheet" type="text/css" href="/css/bootstrap.min.css">
        <link rel="stylesheet" type="text/css" href="/css/sarkart-v2.css?v=30">
    </head>
<body>
    {{>icons}}
    <div class="wrapper">
       {{>sidebar}}
       {{!-- Sidebar collapse handle — straddles the sidebar/content boundary.
            Keeps the #sidebarCollapse id: the engine and ⌘B wiring target it. --}}
       <button type="button" id="sidebarCollapse" class="sidebar-edge-toggle" aria-label="Collapse sidebar" title="Collapse sidebar (⌘B)">
         <svg class="icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M14.5 6 8.5 12l6 6"/></svg>
       </button>
       {{>content}}
    </div>

    <script src="/js/jquery-4.0.0.min.js"></script>
    <script src="/js/plotly-cartesian-3.5.1.min.js"></script>
    <script src="/js/plotly-charts.js?v=26"></script>
    <script src="/js/network-units.js?v=4"></script>
    <script src="/js/html2canvas.min.js"></script>
    <script src="/js/jspdf.umd.min.js"></script>
    <script src="/js/sar-chunked-parser.js"></script>
    <script src="/js/export-pdf.js?v=4"></script>
    <script src="/js/sarkart-ui.js?v=11"></script>
    <script src="/js/landing.js?v=2"></script>
    <script src="/js/ai-summary.js?v=2"></script>
    <script src="/js/heatmap.js?v=9"></script>
</body>
</html>
