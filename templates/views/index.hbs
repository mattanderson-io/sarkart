<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
    <head>
        <meta charset="utf-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
        <meta http-equiv="X-UA-Compatible" content="IE=edge">
        <meta property="og:url" content="https://github.com/mattanderson-io/sarkart" />
        <meta property="og:type" content="website" />
        <meta property="og:title" content="SARkart" />
        <meta property="og:description" content="Fast, local tool for viewing Unix SAR data as interactive charts" />
        <meta property="og:image" content="/images/kart-logo.svg" />
        <title>SARkart</title>
        <link rel="icon" href="/images/kart-logo.svg"  sizes="any" type="image/svg+xml">
        
        <link rel="stylesheet" type="text/css" href="/css/all.min.css">
        <link rel="stylesheet" type="text/css" href="/css/bootstrap.min.css">
        <link rel="stylesheet" type="text/css" href="/css/animate.min.css">
        <link rel="stylesheet" type="text/css" href="/css/sarkart-v1.0.0.min.css">
        <link rel="stylesheet" type="text/css" href="/css/theme-override.css?v=53">

        <!-- Critical inline CSS: prevents the five chart-container cards and
             the FEATURES/DESCRIPTION/HOW TO/FAQ sections from briefly
             rendering as white strips before the external stylesheet and
             the app's JS kick in. Kept tiny on purpose — only the rules
             that solve the landing-page flash. -->
        <style>
          /* Prevent FOUC: hide everything until stylesheets are loaded and
             the initial layout is settled. The body is revealed by a tiny
             inline script at the end of <body> or by the DOMContentLoaded
             event — whichever fires first. */
          body { opacity: 0; }
          body.ready { opacity: 1; transition: opacity 0.15s ease; }

          /* Landing-extras: hidden until JS adds body.landing-extras-open */
          .landing-extra {
            display: none !important;
          }
          body.landing-extras-open .landing-extra { display: flex !important; }
          body.landing-extras-open .section-header.landing-extra { display: block !important; }

          /* Chart containers: hidden by default (prevents white flash on
             initial load). jQuery's .show() sets inline display:block which
             overrides a non-!important stylesheet rule. */
          .contABlock, .contBBlock, .contCBlock, .contDBlock, .contMBlock {
            display: none;
          }
        </style>
    </head>
<body>
    <div class="wrapper">
       {{>sidebar}}
       {{>content}}
    </div>

    <script src="/js/jquery-4.0.0.min.js"></script>
    <script src="/js/bootstrap.bundle.min.js"></script>
    <script src="/js/plotly-cartesian-3.5.1.min.js"></script>
    <script src="/js/highcharts-shim.js"></script>
    <script src="/js/sarkart-v1.0.0.min.js"></script>
    <script src="/js/plotly-charts.js?v=17"></script>
    <script src="/js/html2canvas.min.js"></script>
    <script src="/js/jspdf.umd.min.js"></script>
    <script src="/js/sar-chunked-parser.js"></script>
    <script src="/js/export-pdf.js?v=2"></script>
    <script src="/js/faq.js"></script>
    <script src="/js/landing.js"></script>
    <script src="/js/ai-summary.js"></script>
    <script src="/js/heatmap.js"></script>
    <script>document.body.classList.add('ready');</script>
    
</body>
</html>